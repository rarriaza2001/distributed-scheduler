{
  "title": "Scheduler — Latency & throughput",
  "uid": "sched-latency-tput",
  "schemaVersion": 38,
  "version": 1,
  "tags": ["scheduler", "phase4"],
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "current": { "text": "Prometheus", "value": "Prometheus" }
      }
    ]
  },
  "panels": [
    {
      "type": "timeseries",
      "title": "Completed jobs / s",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [{ "expr": "rate(scheduler_jobs_completed_total[5m])", "legendFormat": "completed/s" }],
      "gridPos": { "h": 7, "w": 24, "x": 0, "y": 0 }
    },
    {
      "type": "timeseries",
      "title": "Queue wait p50/p95/p99",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "expr": "histogram_quantile(0.50, sum(rate(scheduler_job_queue_wait_seconds_bucket[5m])) by (le))", "legendFormat": "p50" },
        { "expr": "histogram_quantile(0.95, sum(rate(scheduler_job_queue_wait_seconds_bucket[5m])) by (le))", "legendFormat": "p95" },
        { "expr": "histogram_quantile(0.99, sum(rate(scheduler_job_queue_wait_seconds_bucket[5m])) by (le))", "legendFormat": "p99" }
      ],
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 7 }
    },
    {
      "type": "timeseries",
      "title": "Execution p50/p95/p99",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "expr": "histogram_quantile(0.50, sum(rate(scheduler_job_execution_seconds_bucket[5m])) by (le))", "legendFormat": "p50" },
        { "expr": "histogram_quantile(0.95, sum(rate(scheduler_job_execution_seconds_bucket[5m])) by (le))", "legendFormat": "p95" },
        { "expr": "histogram_quantile(0.99, sum(rate(scheduler_job_execution_seconds_bucket[5m])) by (le))", "legendFormat": "p99" }
      ],
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 7 }
    },
    {
      "type": "timeseries",
      "title": "End-to-end p50/p95/p99",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "expr": "histogram_quantile(0.50, sum(rate(scheduler_job_end_to_end_seconds_bucket[5m])) by (le))", "legendFormat": "p50" },
        { "expr": "histogram_quantile(0.95, sum(rate(scheduler_job_end_to_end_seconds_bucket[5m])) by (le))", "legendFormat": "p95" },
        { "expr": "histogram_quantile(0.99, sum(rate(scheduler_job_end_to_end_seconds_bucket[5m])) by (le))", "legendFormat": "p99" }
      ],
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 7 }
    }
  ]
}
